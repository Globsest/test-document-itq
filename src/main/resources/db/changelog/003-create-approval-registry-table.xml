<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="003-create-approval-registry-table" author="system">
        <createSequence sequenceName="registry_seq" startValue="1" incrementBy="1"/>

        <createTable tableName="approval_registry">
            <column name="id" type="BIGINT">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="document_id" type="BIGINT">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="approved_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="approved_by" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint
                baseTableName="approval_registry"
                baseColumnNames="document_id"
                constraintName="fk_registry_document"
                referencedTableName="documents"
                referencedColumnNames="id"
                onDelete="CASCADE"/>

        <createIndex indexName="idx_registry_document_id" tableName="approval_registry" unique="true">
            <column name="document_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
